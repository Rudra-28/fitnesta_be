generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model activities {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(150)
  notes           String?           @db.VarChar(255)
  is_active       Boolean?          @default(true)
  created_at      DateTime?         @default(now()) @db.Timestamp(0)
  fee_structures  fee_structures[]
  trainer_batches trainer_batches[]
  batches         batches[]
}

model admins {
  id         Int           @id @default(autoincrement())
  user_id    Int
  scope      admins_scope? @default(sub_admin)
  created_at DateTime?     @default(now()) @db.Timestamp(0)
  users      users         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "admins_ibfk_1")

  @@index([user_id], map: "user_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model commissions {
  id                Int                           @id @default(autoincrement())
  professional_id   Int
  professional_type commissions_professional_type
  source_type       commissions_source_type
  source_id         Int
  base_amount       Decimal                       @db.Decimal(10, 2)
  commission_rate   Decimal                       @db.Decimal(5, 2)
  commission_amount Decimal                       @db.Decimal(10, 2)
  status            commissions_status?           @default(pending)
  created_at        DateTime?                     @default(now()) @db.Timestamp(0)
  professionals     professionals                 @relation(fields: [professional_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "commissions_ibfk_1")

  @@index([professional_id], map: "professional_id")
}

model fee_structures {
  id                Int                              @id @default(autoincrement())
  activity_id       Int
  coaching_type     fee_structures_coaching_type
  society_category  fee_structures_society_category?
  standard          String?                          @db.VarChar(20)
  term_months       Int                              @db.TinyInt
  total_fee         Decimal                          @db.Decimal(10, 2)
  effective_monthly Decimal?                         @db.Decimal(10, 2)
  last_edited_by    Int?
  last_edited_at    DateTime?                        @db.Timestamp(0)
  activities        activities                       @relation(fields: [activity_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fee_structures_ibfk_1")

  @@unique([activity_id, coaching_type, society_category, standard, term_months], map: "uq_fee")
}

model individual_participants {
  id                       Int            @id @default(autoincrement())
  student_id               Int?
  participant_name         String?        @db.VarChar(100)
  mobile                   String?        @db.VarChar(15)
  flat_no                  String?        @db.VarChar(50)
  dob                      DateTime?      @db.Date
  age                      Int?
  society_id               Int?
  society_name             String?        @db.VarChar(150)
  activity                 String?        @db.VarChar(100)
  kits                     String?        @db.Text
  preferred_batch          String?        @db.VarChar(50)
  trainer_professional_id  Int?
  students                 students?      @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "individual_participants_ibfk_1")
  societies                societies?     @relation(fields: [society_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "individual_participants_ibfk_2")
  professionals            professionals? @relation(fields: [trainer_professional_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "individual_participants_ibfk_3")

  @@index([student_id], map: "student_id")
  @@index([society_id], map: "society_id")
  @@index([trainer_professional_id], map: "trainer_professional_id")
}

model marketing_executives {
  id                      Int            @id @default(autoincrement())
  professional_id         Int?
  dob                     DateTime?      @db.Date
  education_qualification String?        @db.VarChar(200)
  previous_experience     String?        @db.Text
  activity_agreement_pdf  String?        @db.VarChar(255)
  professionals           professionals? @relation(fields: [professional_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "marketing_executives_ibfk_1")

  @@index([professional_id], map: "professional_id")
}

model other_areas {
  id                     Int       @id @default(autoincrement())
  student_id             Int?
  sponsor_name           String?   @db.VarChar(100)
  coordinator_name       String?   @db.VarChar(100)
  address                String?   @db.Text
  mobile                 String?   @db.VarChar(15)
  marketing_incharge     String?   @db.VarChar(100)
  activity_agreement_pdf String?   @db.VarChar(255)
  students               students? @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "other_areas_ibfk_1")

  @@index([student_id], map: "student_id")
}

model parent_consents {
  id                   Int       @id @default(autoincrement())
  student_id           Int?
  participant_name     String?   @db.VarChar(100)
  dob                  DateTime? @db.Date
  age                  Int?
  society_name         String?   @db.VarChar(150)
  activity_enrolled    String?   @db.VarChar(150)
  created_at           DateTime? @default(now()) @db.Timestamp(0)
  parent_name          String    @db.VarChar(255)
  emergency_contact_no String    @db.VarChar(20)
  parent_signature_doc String?   @db.VarChar(500)
  consent_date         DateTime  @db.Date
  students             students? @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "parent_consents_ibfk_1")

  @@index([student_id], map: "student_id")
}

model pending_registrations {
  id             Int                           @id @default(autoincrement())
  temp_uuid      String                        @unique(map: "temp_uuid") @db.VarChar(255)
  form_data      Json
  service_type   String                        @db.VarChar(50)
  status         pending_registrations_status? @default(pending)
  created_at     DateTime?                     @default(now()) @db.Timestamp(0)
  reviewed_by    Int?
  review_note    String?                       @db.Text
  reviewed_at    DateTime?                     @db.Timestamp(0)
  assigned_me_id Int?
  assigned_me_at DateTime?                     @db.Timestamp(0)
  professionals  professionals?                @relation(fields: [assigned_me_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "pending_registrations_fk_me")

  @@index([assigned_me_id], map: "pending_registrations_fk_me")
}

model personal_tutors {
  id                      Int            @id @default(autoincrement())
  student_id              Int?
  dob                     DateTime?      @db.Date
  standard                String?        @db.VarChar(50)
  batch                   String?        @db.VarChar(50)
  teacher_for             String?        @db.VarChar(100)
  teacher_professional_id Int?
  students                students?      @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "personal_tutors_ibfk_1")
  professionals           professionals? @relation(fields: [teacher_professional_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "personal_tutors_ibfk_2")

  @@index([student_id], map: "student_id")
  @@index([teacher_professional_id], map: "teacher_professional_id")
}

model professionals {
  id                      Int                            @id @default(autoincrement())
  referral_code           String?                        @unique(map: "referral_code") @db.VarChar(12)
  user_id                 Int?
  profession_type         professionals_profession_type?
  pan_card                String?                        @db.VarChar(255)
  adhar_card              String?                        @db.VarChar(255)
  relative_name           String?                        @db.VarChar(100)
  relative_contact        String?                        @db.VarChar(15)
  own_two_wheeler         Boolean?
  communication_languages String?                        @db.Text
  place                   String?                        @db.VarChar(100)
  date                    DateTime?                      @db.Date
  commissions             commissions[]
  marketing_executives    marketing_executives[]
  users                   users?                         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "professionals_ibfk_1")
  schools                 schools[]
  societies               societies[]
  teachers                teachers[]
  trainer_batches         trainer_batches[]
  trainers                trainers[]
  travelling_allowances   travelling_allowances[]
  vendors                 vendors[]
  wallets                 wallets?
  individual_participants individual_participants[]
  personal_tutors         personal_tutors[]
  pending_registrations   pending_registrations[]
  batches                 batches[]
  sessions                sessions[]

  @@index([user_id], map: "user_id")
}

model school_students {
  id           Int                       @id @default(autoincrement())
  student_id   Int
  school_id    Int
  student_name String?                   @db.VarChar(150)
  standard     String?                   @db.VarChar(50)
  address      String?                   @db.Text
  activities   String?                   @db.Text
  kit_type     String?                   @db.Text
  created_at   DateTime?                 @default(now()) @db.Timestamp(0)
  students     students                  @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "school_students_ibfk_1")
  schools      schools                   @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "school_students_ibfk_2")

  @@index([school_id], map: "school_id")
  @@index([student_id], map: "student_id")
}

model schools {
  id                            Int                      @id @default(autoincrement())
  user_id                       Int?
  me_professional_id            Int?
  school_name                   String?                  @db.VarChar(150)
  address                       String?                  @db.Text
  pin_code                      String?                  @db.VarChar(10)
  state                         String?                  @db.VarChar(100)
  language_medium               String?                  @db.VarChar(100)
  landline_no                   String?                  @db.VarChar(20)
  principal_name                String?                  @db.VarChar(100)
  principal_contact             String?                  @db.VarChar(15)
  activity_coordinator          String?                  @db.VarChar(100)
  agreement_signed_by_authority Boolean?                 @default(false)
  activity_agreement_pdf        String?                  @db.VarChar(255)
  me_id                         Int?
  approval_status               schools_approval_status? @default(pending)
  created_at                    DateTime?                @default(now()) @db.Timestamp(0)
  school_students               school_students[]
  professionals                 professionals?           @relation(fields: [me_professional_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "schools_ibfk_1")
  trainer_batches               trainer_batches[]
  batches                       batches[]

  @@index([me_professional_id], map: "me_professional_id")
}

model payments {
  id                  Int              @id @default(autoincrement())
  temp_uuid           String           @unique(map: "temp_uuid") @db.VarChar(255)
  razorpay_order_id   String           @db.VarChar(100)
  razorpay_payment_id String           @unique(map: "razorpay_payment_id") @db.VarChar(100)
  service_type        String           @db.VarChar(50)
  amount              Decimal          @db.Decimal(10, 2)
  currency            String?          @default("INR") @db.VarChar(10)
  term_months         Int              @default(1) @db.TinyInt
  status              payments_status? @default(captured)
  student_user_id     Int?
  captured_at         DateTime         @default(now()) @db.Timestamp(0)
  users               users?           @relation(fields: [student_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "payments_ibfk_1")

  @@index([student_user_id], map: "student_user_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model societies {
  society_unique_id             String                     @unique(map: "society_unique_id") @db.VarChar(50)
  id                            Int                        @id @default(autoincrement())
  registered_by_user_id         Int?
  society_name                  String?                    @db.VarChar(150)
  society_category              societies_society_category
  address                       String?                    @db.Text
  pin_code                      String?                    @db.VarChar(10)
  total_participants            Int?
  no_of_flats                   Int?
  proposed_wing                 String?                    @db.VarChar(50)
  authority_role                String?                    @db.VarChar(50)
  authority_person_name         String?                    @db.VarChar(100)
  contact_number                String?                    @db.VarChar(15)
  playground_available          Boolean?
  coordinator_name              String?                    @db.VarChar(100)
  coordinator_number            String?                    @db.VarChar(15)
  agreement_signed_by_authority Boolean?                   @default(false)
  me_professional_id            Int?
  activity_agreement_pdf        String?                    @db.VarChar(255)
  approval_status               societies_approval_status? @default(pending)
  created_at                    DateTime?                  @default(now()) @db.Timestamp(0)
  professionals                 professionals?             @relation(fields: [me_professional_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "societies_fk_me")
  users                         users?                     @relation(fields: [registered_by_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "societies_fk_user")
  individual_participants       individual_participants[]
  trainer_batches               trainer_batches[]
  batches                       batches[]

  @@index([me_professional_id], map: "societies_fk_me")
  @@index([registered_by_user_id], map: "societies_fk_user")
}

model students {
  id                      Int                       @id @default(autoincrement())
  user_id                 Int?
  student_type            students_student_type?
  individual_participants individual_participants[]
  other_areas             other_areas[]
  parent_consents         parent_consents[]
  personal_tutors         personal_tutors[]
  school_students         school_students[]
  users                   users?                    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "students_ibfk_1")
  batch_students          batch_students[]
  sessions                sessions[]
  session_participants    session_participants[]
  session_feedback        session_feedback[]

  @@index([user_id], map: "user_id")
}

model teachers {
  id                 Int            @id @default(autoincrement())
  professional_id    Int?
  subject            String?        @db.VarChar(100)
  experience_details String?        @db.Text
  ded_doc            String?        @db.VarChar(255)
  bed_doc            String?        @db.VarChar(255)
  other_doc          String?        @db.VarChar(255)
  professionals      professionals? @relation(fields: [professional_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "teachers_ibfk_1")

  @@index([professional_id], map: "professional_id")
}

model trainer_batches {
  id                      Int           @id @default(autoincrement())
  trainer_professional_id Int
  society_id              Int?
  school_id               Int?
  activity_id             Int?
  batch_date              DateTime      @db.Date
  batch_time              DateTime?     @db.Time(0)
  created_at              DateTime?     @default(now()) @db.Timestamp(0)
  professionals           professionals @relation(fields: [trainer_professional_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "trainer_batches_ibfk_1")
  societies               societies?    @relation(fields: [society_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "trainer_batches_ibfk_2")
  schools                 schools?      @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "trainer_batches_ibfk_3")
  activities              activities?   @relation(fields: [activity_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "trainer_batches_ibfk_4")

  @@index([activity_id], map: "activity_id")
  @@index([school_id], map: "school_id")
  @@index([society_id], map: "society_id")
  @@index([trainer_professional_id], map: "trainer_professional_id")
}

model trainers {
  id                 Int            @id @default(autoincrement())
  professional_id    Int?
  player_level       String?        @db.VarChar(50)
  category           String?        @db.VarChar(100)
  specified_game     Json?
  specified_skills   Json?
  experience_details String?        @db.Text
  qualification_docs String?        @db.VarChar(255)
  documents          String?        @db.VarChar(255)
  professionals      professionals? @relation(fields: [professional_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "trainers_ibfk_1")

  @@index([professional_id], map: "professional_id")
}

model travelling_allowances {
  id                      Int                           @id @default(autoincrement())
  trainer_professional_id Int
  allowance_date          DateTime                      @db.Date
  batches_count           Int                           @db.TinyInt
  amount                  Decimal                       @db.Decimal(6, 2)
  status                  travelling_allowances_status? @default(pending)
  created_at              DateTime?                     @default(now()) @db.Timestamp(0)
  updated_at              DateTime?                     @default(now()) @db.Timestamp(0)
  professionals           professionals                 @relation(fields: [trainer_professional_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "travelling_allowances_ibfk_1")

  @@unique([trainer_professional_id, allowance_date], map: "uq_ta_per_day")
}

model users {
  id              Int                   @id @default(autoincrement())
  uuid            String?               @unique(map: "users_uuid") @db.Char(36)
  role            String                @db.VarChar(50)
  subrole         String?               @db.VarChar(50)
  full_name       String?               @db.VarChar(100)
  mobile          String?               @unique(map: "mobile") @db.VarChar(15)
  email           String?               @db.VarChar(100)
  address         String?               @db.Text
  photo           String?               @db.VarChar(255)
  created_at      DateTime?             @default(now()) @db.Timestamp(0)
  is_verified     Boolean?              @default(false)
  approval_status users_approval_status @default(pending)
  approved_by     Int?
  approval_note   String?               @db.Text
  admins          admins[]
  professionals   professionals[]
  societies       societies[]
  students        students[]
  payments        payments[]
  kit_orders      kit_orders[]
}

model vendors {
  id              Int              @id @default(autoincrement())
  professional_id Int?
  store_name      String?          @db.VarChar(150)
  store_address   String?          @db.Text
  store_location  String?          @db.VarChar(150)
  gst_certificate String?          @db.VarChar(255)
  professionals   professionals?   @relation(fields: [professional_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "vendors_ibfk_1")
  vendor_products vendor_products[]
  kit_orders      kit_orders[]

  @@index([professional_id], map: "professional_id")
}

model vendor_products {
  id                   Int      @id @default(autoincrement())
  vendor_id            Int
  product_image        String?  @db.VarChar(255)
  product_name         String   @db.VarChar(150)
  sports_category      String   @db.VarChar(100)
  price                Decimal  @db.Decimal(10, 2)
  selling_price        Decimal  @db.Decimal(10, 2)
  stock                Int      @default(0)
  description          String?  @db.Text
  within_city_charge   Decimal  @default(0.00) @db.Decimal(10, 2)
  within_state_charge  Decimal  @default(0.00) @db.Decimal(10, 2)
  outside_state_charge Decimal  @default(0.00) @db.Decimal(10, 2)
  age_groups           Json?
  created_at           DateTime @default(now()) @db.Timestamp(0)
  vendors              vendors    @relation(fields: [vendor_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "vendor_products_ibfk_1")
  kit_orders           kit_orders[]

  @@index([vendor_id], map: "vendor_id")
}

model wallets {
  id              Int           @id @default(autoincrement())
  professional_id Int           @unique(map: "professional_id")
  balance         Decimal?      @default(0.00) @db.Decimal(10, 2)
  updated_at      DateTime?     @default(now()) @db.Timestamp(0)
  professionals   professionals @relation(fields: [professional_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "wallets_ibfk_1")
}

/// Stores all configurable commission rates and flat amounts.
/// Admin can view and edit these via the admin panel.
model commission_rules {
  id                Int      @id @default(autoincrement())
  rule_key          String   @unique @db.VarChar(100)
  professional_type String   @db.VarChar(50)
  description       String   @db.VarChar(255)
  rule_type         String   @db.VarChar(20)
  value             Decimal  @db.Decimal(10, 2)
  updated_at        DateTime @default(now()) @db.Timestamp(0)
}

enum admins_scope {
  super_admin
  sub_admin
}

enum commissions_professional_type {
  marketing_executive
  trainer
  teacher
}

enum fee_structures_coaching_type {
  group_coaching
  individual_coaching
  personal_tutor
  school_student
}

enum students_student_type {
  group_coaching
  individual_coaching
  personal_tutor
  school_student
}

enum commissions_source_type {
  group_coaching_society
  group_coaching_school
  group_coaching_other
  individual_coaching
  personal_tutor
  event_ticket
  school_registration
}

enum fee_structures_society_category {
  A_ @map("A+")
  A
  B
  custom
}

enum pending_registrations_status {
  pending
  approved
  rejected
}

enum professionals_profession_type {
  trainer
  teacher
  marketing_executive
  vendor
}

enum societies_society_category {
  A_ @map("A+")
  A
  B
  custom
}

enum travelling_allowances_status {
  pending
  paid
}

enum school_students_kit_type {
  Cricket
  Football
  Volleyball
  Karate
}

enum commissions_status {
  on_hold
  pending
  approved
  paid
}

enum users_approval_status {
  pending
  approved
  rejected
}

enum schools_approval_status {
  pending
  approved
  rejected
}

enum societies_approval_status {
  pending
  approved
  rejected
}

enum payments_status {
  captured
  refunded
  failed
}

model kit_orders {
  id                  Int                    @id @default(autoincrement())
  student_user_id     Int
  product_id          Int
  vendor_id           Int
  quantity            Int                    @default(1)
  unit_price          Decimal                @db.Decimal(10, 2)
  delivery_charge     Decimal                @db.Decimal(10, 2)
  delivery_zone       kit_orders_zone
  kit_order_zone_user kit_orders_zone?
  total_amount        Decimal                @db.Decimal(10, 2)
  payment_status      kit_orders_pay_status  @default(pending)
  order_status        kit_orders_status      @default(new_order)
  razorpay_order_id   String?                @db.VarChar(100)
  razorpay_payment_id String?                @unique @db.VarChar(100)
  delivery_name       String                 @db.VarChar(100)
  delivery_phone      String                 @db.VarChar(15)
  delivery_address    String                 @db.Text
  delivery_city       String                 @db.VarChar(100)
  delivery_state      String                 @db.VarChar(100)
  delivery_pincode    String                 @db.VarChar(10)
  age_group           String?                @db.VarChar(20)
  created_at          DateTime               @default(now()) @db.Timestamp(0)
  users               users                  @relation(fields: [student_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendor_products     vendor_products        @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendors             vendors                @relation(fields: [vendor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([student_user_id])
  @@index([product_id])
  @@index([vendor_id])
}

enum kit_orders_zone {
  within_city
  within_state
  outside_state
}

enum kit_orders_pay_status {
  pending
  paid
  failed
}

enum kit_orders_status {
  new_order
  in_progress
  ready_for_delivery
  out_for_delivery
  mark_as_delivered
  completed
  rejected
}

// ─── Session Management ────────────────────────────────────────────────────

enum batches_batch_type {
  group_coaching
  school_student
}

enum batches_professional_type {
  trainer
  teacher
}

enum sessions_status {
  scheduled
  ongoing
  completed
  cancelled
}

enum sessions_session_type {
  group_coaching
  school_student
  personal_tutor
  individual_coaching
}

model batches {
  id                   Int                        @id @default(autoincrement())
  batch_type           batches_batch_type
  society_id           Int?
  school_id            Int?
  activity_id          Int
  professional_id      Int
  professional_type    batches_professional_type
  batch_name           String?                    @db.VarChar(100)
  days_of_week         Json
  start_time           DateTime                   @db.Time(0)
  end_time             DateTime                   @db.Time(0)
  start_date           DateTime                   @db.Date
  end_date             DateTime                   @db.Date
  is_active            Boolean?                   @default(true)
  created_at           DateTime?                  @default(now()) @db.Timestamp(0)
  updated_at           DateTime?                  @default(now()) @db.Timestamp(0)

  societies            societies?                 @relation(fields: [society_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  schools              schools?                   @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  activities           activities                 @relation(fields: [activity_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  professionals        professionals              @relation(fields: [professional_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  batch_students       batch_students[]
  sessions             sessions[]

  @@index([society_id])
  @@index([school_id])
  @@index([activity_id])
  @@index([professional_id])
  @@index([batch_type])
  @@index([start_date, end_date])
}

model batch_students {
  id         Int       @id @default(autoincrement())
  batch_id   Int
  student_id Int
  joined_at  DateTime? @default(now()) @db.Timestamp(0)

  batches    batches   @relation(fields: [batch_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students   students  @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([batch_id, student_id], map: "uq_batch_student")
  @@index([student_id])
}

model sessions {
  id               Int                    @id @default(autoincrement())
  session_type     sessions_session_type
  batch_id         Int?
  student_id       Int?
  professional_id  Int
  scheduled_date   DateTime               @db.Date
  start_time       DateTime               @db.Time(0)
  end_time         DateTime               @db.Time(0)
  status           sessions_status?       @default(scheduled)
  cancel_reason    String?                @db.VarChar(255)
  in_time          DateTime?              @db.Timestamp(0)
  out_time         DateTime?              @db.Timestamp(0)
  created_at       DateTime?              @default(now()) @db.Timestamp(0)
  updated_at       DateTime?              @default(now()) @db.Timestamp(0)

  batches              batches?           @relation(fields: [batch_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  students             students?          @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  professionals        professionals      @relation(fields: [professional_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  session_participants session_participants[]
  session_feedback     session_feedback[]

  @@index([batch_id])
  @@index([student_id])
  @@index([professional_id])
  @@index([scheduled_date])
  @@index([status])
  @@index([session_type])
  @@index([professional_id, scheduled_date])
  @@index([student_id, scheduled_date])
}

model session_feedback {
  id         Int       @id @default(autoincrement())
  session_id Int
  student_id Int
  rating     Int       // 1–5
  comment    String?   @db.VarChar(500)
  created_at DateTime? @default(now()) @db.Timestamp(0)

  sessions   sessions  @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students   students  @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([session_id, student_id], map: "uq_session_feedback")
  @@index([session_id])
  @@index([student_id])
}

model session_participants {
  id         Int       @id @default(autoincrement())
  session_id Int
  student_id Int
  attended   Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(0)

  sessions   sessions  @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students   students  @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([session_id, student_id], map: "uq_session_participant")
  @@index([student_id])
}
